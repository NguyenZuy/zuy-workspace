<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/Resource/UI/dialog_box.uss?fileID=7433441132597879392&amp;guid=41469ab7befa36347a0cc463c42538e4&amp;type=3#dialog_box" />
    <engine:VisualElement name="overlay" style="flex-grow: 1;" />
    <engine:VisualElement name="container" style="flex-grow: 1;">
        <engine:VisualElement name="background" style="flex-grow: 1; position: absolute; top: auto; left: auto; width: 100%; height: 100%; background-color: rgb(255, 255, 255);" />
        <engine:Label name="title" />
    </engine:VisualElement>
</engine:UXML>
