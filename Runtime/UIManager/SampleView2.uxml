<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <engine:VisualElement name="container" style="flex-grow: 1; justify-content: center;">
        <engine:VisualElement name="overlay" style="flex-grow: 1; position: absolute; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.78);" />
        <engine:VisualElement name="background" style="flex-grow: 1; width: 1200px; height: 700px; align-self: center; position: absolute; justify-content: center; background-color: rgb(255, 255, 255);">
            <engine:Label text="This is sample view 2" name="title" style="font-size: 100px; -unity-font-style: normal; -unity-text-align: upper-center;" />
            <engine:Label text="Made by NguyenZuy" name="title" style="font-size: 50px; -unity-font-style: normal; -unity-text-align: upper-center; color: rgb(255, 0, 0);" />
        </engine:VisualElement>
    </engine:VisualElement>
</engine:UXML>
